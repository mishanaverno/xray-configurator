[
  {
    "listen": "127.0.0.1",
    "port": 1050,
    "protocol": "vless",
    "tag": "xhttp-in",
    "settings": {
      "clients": [
        {
          "id": "${XRAY_UUID}",
          "email": "reality-server"
        }
      ],
      "decryption": "none"
    },
    "streamSettings": {
      "network": "xhttp",
      "security": "tls",
      "tlsSettings": {
        "serverName": "${HOST}",
        "alpn": [
          "h2"
        ],
        "certificates": [
          {
            "certificateFile": "${TLS_CERT_FILE}",
            "keyFile": "${TLS_KEY_FILE}"
          }
        ]
      },
      "xhttpSettings": {
        "host": "${HOST}",
        "path": "${SLAVE_PATH}",
        "mode": "auto"
      }
    },
    "sniffing": {
      "enabled": true,
      "destOverride": [
        "http",
        "tls"
      ]
    }
  }
]
