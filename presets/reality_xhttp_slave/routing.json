            "outboundTag": "block"
        },
        {
            "type": "field",
            "domain": [
                "domain:chatgpt.com",
                "domain:openai.com",
                "domain:auth0.com",
                "domain:oaistatic.com",
                "domain:oaiusercontent.com",
                "domain:statsigapi.net",
                "domain:featuregates.org",
                "domain:intercom.io",
                "domain:intercomcdn.com",
                "geosite:openai"
            ],
            "outboundTag": "warp"
        },
        {
            "type": "field",
            "domain": ["geosite:category-gov-ru", "domain:ru"],
